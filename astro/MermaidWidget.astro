---
const { widget } = Astro.props;
const mermaidCode = widget?.mermaid || '';
const placeholder = widget?.aposPlaceholder;
---

<div class="mermaid-container">
  {placeholder ? (
    <div class="mermaid-placeholder">
      <p>📊 Mermaid diagram placeholder</p>
      <p>Click the edit button to add your diagram</p>
    </div>
  ) : (
    <mermaid-widget code={mermaidCode}>
      <pre class="mermaid">{mermaidCode}</pre>
    </mermaid-widget>
  )}
</div>

<script>
  // Simple approach - just like your original widget player
  import('mermaid').then(async ({ default: mermaid }) => {
    mermaid.initialize({ startOnLoad: false });

    // Run mermaid on all .mermaid elements
    await mermaid.run({
      nodes: document.querySelectorAll('.mermaid')
    });
  });
</script>

<style>
  .mermaid-container {
    width: 100%;
    margin: 1rem 0;
  }
  pre.mermaid {
    display: block;
    background: #fff;
    width: 100%;
    border: 1px solid #ddd;
    padding: 1rem;
    border-radius: 4px;
  }
  .mermaid-placeholder {
    padding: 2rem;
    text-align: center;
    background: #f5f5f5;
    border: 2px dashed #ccc;
    border-radius: 4px;
    color: #666;
  }
</style>
