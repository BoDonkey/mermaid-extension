---
/**
 * Props:
 *  - code: string (the Mermaid definition, e.g., "graph TD; A-->B;")
 *  - class (optional): string
 *  - style (optional): string
 */
const { widget } = Astro.props;
const uniqueId = `mermaid-widget-${Math.random().toString(36).slice(2)}`;
---

<div data-mermaid-widget data-widget-id={uniqueId}>
  <!-- Keep raw source hidden; render SVG into .mermaid-target -->
  <pre class="mermaid-code" style="display:none;">{widget.mermaid}</pre>
  <div class="mermaid-target" aria-live="polite"></div>
</div>

<script>
  /**
   * Manages Mermaid diagram rendering for a single widget instance
   */
  class MermaidWidget {
    constructor(container) {
      this.container = container;
      this.widgetId = container.dataset.widgetId;
      this.target = container.querySelector('.mermaid-target');
      this.codeEl = container.querySelector('.mermaid-code');
      this.rendered = false;
      this.CDN = 'https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js';
    }

    async ensureMermaid() {
      if (window.mermaid) return Promise.resolve();
      return new Promise((resolve, reject) => {
        const s = document.createElement('script');
        s.src = this.CDN;
        s.async = true;
        s.onload = () => {
          window.mermaid.initialize({
            startOnLoad: false,
            securityLevel: 'loose',
            theme: 'default'
          });
          resolve();
        };
        s.onerror = (e) => reject(e);
        document.head.appendChild(s);
      });
    }

    async render() {
      if (this.rendered) return;

      try {
        await this.ensureMermaid();
        
        this.target.style.visibility = 'hidden';
        const id = 'mermaid-' + Math.random().toString(36).slice(2);
        const src = (this.codeEl.textContent || '').trim();

        // Render to a temporary container to catch error SVGs
        const { svg } = await window.mermaid.render(id, src);
        
        // Check if the SVG contains error indicators
        if (svg.includes('Syntax error') || svg.includes('Parse error')) {
          this.target.innerHTML = '<div style="color:red;padding:10px;background:#ffe6e6;border:1px solid #ff0000;border-radius:4px;">Error rendering diagram. Please check your Mermaid syntax.</div>';
        } else {
          this.target.innerHTML = svg;
        }
        
        // Clean up any error SVGs that Mermaid might have inserted elsewhere
        document.querySelectorAll('svg[id^="d"]').forEach(svg => {
          if (svg.querySelector('text')?.textContent?.includes('Syntax error')) {
            svg.remove();
          }
        });
      } catch (err) {
        console.error('Mermaid rendering error:', err);
        this.target.innerHTML = '<div style="color:red;padding:10px;background:#ffe6e6;border:1px solid #ff0000;border-radius:4px;">Error rendering diagram. Please check your Mermaid syntax.</div>';
        
        // Clean up any orphaned error SVGs
        document.querySelectorAll('svg[id^="mermaid-"]').forEach(svg => {
          if (!this.container.contains(svg)) {
            svg.remove();
          }
        });
      } finally {
        this.target.style.visibility = 'visible';
        this.rendered = true;
      }
    }

    destroy() {
      this.rendered = false;
    }
  }

  const mermaidWidgets = new Map();

  // Call once now (in case we're on a static page / in-context editing)
  queueMicrotask(initMermaidWidgets);

  // Make init idempotent & debounced (DOM can churn a lot in the modal)
  let initTimer = null;
  function scheduleInit(delay = 50) {
    if (initTimer) clearTimeout(initTimer);
    initTimer = setTimeout(initMermaidWidgets, delay);
  }

  function initMermaidWidgets() {
    // Reset any previous instances so re-renders are clean
    mermaidWidgets.forEach(w => w.destroy());
    mermaidWidgets.clear();

    // (Re)discover and render all current widgets
    document.querySelectorAll('[data-mermaid-widget]').forEach(container => {
      const widgetId = container.dataset.widgetId;
      if (!widgetId) return;
      const w = new MermaidWidget(container);
      mermaidWidgets.set(widgetId, w);
      w.render();
    });
  }

  const mo = new MutationObserver((mutations) => {
    for (const m of mutations) {
      // If any mutation added a mermaid widget or changed the code inside one, re-init
      const added = [...m.addedNodes].some(
        n => n.nodeType === 1 && (n.matches?.('[data-mermaid-widget]') || n.querySelector?.('[data-mermaid-widget]'))
      );
      const isCodeChange = m.target?.matches?.('.mermaid-code') || m.target?.closest?.('[data-mermaid-widget]');
      if (added || isCodeChange) {
        scheduleInit(75);
        break;
      }
    }
  });

  mo.observe(document.body, { childList: true, subtree: true, characterData: true });

  if (window.apos?.bus?.$on) {
    // Fires when a modal opens (page editor, piece editor, etc.)
    apos.bus.$on('modal-opened', () => scheduleInit(75));
    // Fires when areas/widgets refresh after edits or insertions
    apos.bus.$on('refreshed', () => scheduleInit(50));
  }

  // (Optional) Fallback: run after the current tick to catch late DOM paint
  requestAnimationFrame(() => scheduleInit(100));
</script>
